# ============================================================
# .env.example — Variables de entorno para conti-backend
# ============================================================
# Copiar a .env y completar los valores.
# NUNCA commitear .env a git.
# ============================================================

# ── API Keys (OBLIGATORIO) ──────────────────────────────────
# Kilocode AI Gateway
KILOCODE_API_KEY=

# DeepSeek (fallback LLM)
DEEPSEEK_API_KEY=

# Xiaomi Token Plan Singapore (OMP + OpenHands)
XIAOMI_TOKEN_PLAN_SGP_API_KEY=

# MCP Odoo credentials
CONTI_MCP_API_KEY=sk-conti-mcp-write

# RAG Flamehaven
FLAMEHAVEN_API_KEY=

# Gemini (metadata enrichment en ingesta RAG)
GEMINI_API_KEY=

# SpineDigest (resumidor de documentos) - usa Gemini como backend
SPINEDIGEST_LLM_API_KEY=

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── MercadoPago ─────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_SANDBOX=true
MERCADOPAGO_SUCCESS_URL=
MERCADOPAGO_FAILURE_URL=
MERCADOPAGO_PENDING_URL=
MERCADOPAGO_NOTIFICATION_URL=

# ── OpenHands Agent Server ──────────────────────────────────
OPENHANDS_LLM_MODEL=openai/mimo-v2.5-pro
OPENHANDS_LLM_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
OPENHANDS_LLM_MAX_TOKENS=4000
OPENHANDS_TIMEOUT=600
OPENHANDS_LLM_API_KEY=

# ── OMP Runtime (oh-my-pi) ─────────────────────────────────
CONTI_USE_OMP_AGENT=true
OMP_HOST=conti-omp
OMP_PORT=7891
OMP_PROMPT_TIMEOUT=360
OMP_VERSION=v16.2.9
OMP_SMOL_MODEL=
OMP_SLOW_MODEL=
OMP_PLAN=0

# ── MCP Odoo ────────────────────────────────────────────────
ODOO_TENANT_ID=resto
MESA_ID=1

# ── SpineDigest ─────────────────────────────────────────────
# Provider: google (default) | openai | openai_compatible
# Para usar Xiaomi: openai_compatible con XIAOMI_TOKEN_PLAN_SGP_API_KEY
SPINEDIGEST_LLM_PROVIDER=google
SPINEDIGEST_LLM_MODEL=gemini-2.0-flash
SPINEDIGEST_LLM_API_KEY=
SPINEDIGEST_LLM_BASE_URL=
# ── Ponytail Tracing ────────────────────────────────────────
PONYTAIL_TRACE_DIR=.ponytail/traces/
PONYTAIL_COMMIT_TRACES=true
PONYTAIL_PUSH_TRACES=true
PONYTAIL_TRACE_RETENTION_DAYS=90

# ── Docker ──────────────────────────────────────────────────
DOCKER_API_VERSION=1.44
